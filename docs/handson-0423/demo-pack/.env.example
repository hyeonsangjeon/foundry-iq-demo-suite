# Fabric IQ Ontology MCP — Configuration
# Copy to .env and adjust as needed.

# ---- Tenant & Identity ---------------------------------------------------
# The tenant that owns the Fabric workspace hosting the ontology.
# For the current Private Preview this is the tenant Microsoft enabled
# during your allowlist request.
TENANT_ID="<YOUR_TENANT_ID>"

# ---- Fabric API host -----------------------------------------------------
# Private Preview endpoint: <your-preview-host>.fabric.microsoft.com
#                           (Microsoft assigns this when your tenant is allowlisted)
# Public endpoint (once GA): api.fabric.microsoft.com
MCP_HOST="<YOUR_FABRIC_HOST>.fabric.microsoft.com"

# ---- Workspace & Ontology identifiers ------------------------------------
# These identify a specific Fabric ontology item.
WORKSPACE_ID="<YOUR_WORKSPACE_ID>"
ONTOLOGY_ID="<YOUR_ONTOLOGY_ID>"

# ---- Derived URL (do not edit) -------------------------------------------
# Construction mirrors the path returned in the PM guide.
MCP_URL="https://${MCP_HOST}/v1/mcp/dataPlane/workspaces/${WORKSPACE_ID}/items/${ONTOLOGY_ID}/ontologyEndpoint"

# ---- Optional: External PoC fallback (for later, once GA) ----------------
# TENANT_ID="<YOUR_TENANT_ID>"
# MCP_HOST="api.fabric.microsoft.com"
# WORKSPACE_ID="<YOUR_WORKSPACE_ID>"
# ONTOLOGY_ID="<YOUR_ONTOLOGY_ID>"

# ─── Layer 2: Foundry IQ KS path (added 2026-04-22) ─────────────────────
# Required for demo_07_*_via_kb.sh ~ demo_11_*_via_kb.sh.
# These call the Foundry IQ Retrieve API on Azure AI Search instead of
# hitting the Fabric MCP endpoint directly. The KS (kind: fabricIQ) on
# the AI Search side federates back to the same Fabric ontology.
#
# If any value below is left as a placeholder, the Layer 2 demo scripts
# fall back to OFFLINE samples (samples/07~11_*.json).

AZURE_SEARCH_ENDPOINT="https://<YOUR_SEARCH_SERVICE>.search.windows.net"
AZURE_SEARCH_API_KEY="{YOUR_AZURE_SEARCH_ADMIN_KEY}"
AZURE_SEARCH_API_VERSION="2025-11-01-preview"
KB_NAME="<YOUR_KB_NAME>"
DEFAULT_KS_NAME="<YOUR_FABRICIQ_KS_NAME>"
SEARCH_INDEX_KS_NAME="<YOUR_SEARCHINDEX_KS_NAME>"

# Tenant that issues the OBO token used by the Layer 2 path. This must be
# the tenant where the Fabric ontology lives (the Private Preview tenant),
# even when the Azure AI Search service itself lives in a different tenant.
PREVIEW_TENANT_ID="<YOUR_PREVIEW_TENANT_ID>"
